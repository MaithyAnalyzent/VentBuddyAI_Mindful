MONGODB_URI="mongodb+srv://<user>:<url-encoded-password>@<cluster>/<database>?retryWrites=true&w=majority&tls=true"
DB_NAME="ventbuddy_ai"
CORS_ORIGINS="https://<frontend-service>.onrender.com"
FRONTEND_URL="https://<frontend-service>.onrender.com"
OPENAI_API_KEY="sk-proj-..."
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_STT_MODEL="whisper-1"
OPENAI_TTS_MODEL="tts-1"
JWT_SECRET="<generate-a-long-random-secret>"
ADMIN_EMAIL="admin@ventbuddy.ai"
ADMIN_PASSWORD="<set-a-strong-initial-admin-password>"
TELEGRAM_BOT_TOKEN="<optional-telegram-bot-token>"
TELEGRAM_BOT_NAME="VentBuddy AI"
TELEGRAM_POLLING_ENABLED=true
